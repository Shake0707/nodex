# ─── Host Nginx config for nodex.uz ───
# Place this file at /etc/nginx/sites-available/nodex.uz
# Then: ln -s /etc/nginx/sites-available/nodex.uz /etc/nginx/sites-enabled/
# Then: sudo nginx -t && sudo systemctl reload nginx
#
# SSL is managed here (host level) via certbot.
# Docker nginx on port 2080 handles internal proxying only.

server {
    listen 80;
    server_name nodex.uz www.nodex.uz;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    server_name nodex.uz www.nodex.uz;

    ssl_certificate /etc/letsencrypt/live/nodex.uz/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/nodex.uz/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    client_max_body_size 10m;

    location / {
        proxy_pass http://127.0.0.1:2080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
